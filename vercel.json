{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/home/:homeId",
      "destination": "/api/og-meta?path=/home/:homeId&homeId=:homeId"
    },
    {
      "source": "/home/:homeId/:rest*",
      "destination": "/api/og-meta?path=/home/:homeId/:rest*&homeId=:homeId"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
